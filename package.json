{
  "name": "finance-whatsapp-saas",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api,worker,baileys -c blue,green,magenta,yellow \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:baileys\"",
    "dev:web": "npm run dev --workspace @finance/web",
    "dev:api": "npm run dev --workspace @finance/api",
    "dev:worker": "npm run dev --workspace @finance/worker",
    "dev:baileys": "cd ../baileys-microservice && node index.js",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace @finance/api",
    "start:api": "npm run start --workspace @finance/api",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}