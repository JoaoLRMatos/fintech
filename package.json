{
  "name": "finance-saas",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace @finance/web",
    "dev:api": "npm run dev --workspace @finance/api",
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm run build --workspace @finance/api",
    "build:web": "npm run build --workspace @finance/web",
    "start:api": "npm run start --workspace @finance/api",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}